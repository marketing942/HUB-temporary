# ============================================================
# CPPEM HUB — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# --- Google Sheets ---
# ID da planilha (extraído da URL do Google Sheets)
GOOGLE_SHEETS_ID=1ZzKYar--5x31ov0WSn-7Xmisv7Vw3FEhBN5IdGP-hgA

# E-mail da Service Account (Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-service-account@projeto.iam.gserviceaccount.com

# Chave privada da Service Account
# No Vercel: cole o valor completo incluindo as aspas e os \n literais
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END RSA PRIVATE KEY-----"

# Aba/range da planilha.
# Se seus dados estão na primeira aba: A1:Z1000
# Se estão em uma aba específica: NomeDaAba!A1:Z1000
# Acesse /api/sheets-test (em dev) para ver os nomes das abas
GOOGLE_SHEETS_RANGE=A1:Z1000

# --- Supabase ---
# URL do projeto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Chave anônima pública (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço — NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Cache ---
# Segredo para o endpoint POST /api/revalidate (forçar refresh do cache)
# Opcional — gere qualquer string aleatória forte
REVALIDATE_SECRET=
